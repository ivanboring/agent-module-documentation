{
  "name": "AI Assistant API",
  "data_name": "ai_assistant_api",
  "description": "Adds decoupled AI Assistants for any frontend to work with.",
  "version": "1.4.x",
  "release_stability": "experimental",
  "package": "AI Tools",
  "part_of": "ai",
  "composer_namespace": "drupal/ai",
  "composer_requirements": {},
  "dependent_modules": ["ai:ai"],
  "configure": "entity.ai_assistant.collection",
  "core_version_requirement": "^10.4 || ^11",
  "active_installs": null,
  "project_url": "https://www.drupal.org/project/ai",
  "license": "GPL-2.0-or-later",
  "php_requirement": null,
  "library_dependencies": [],
  "suggests": {},
  "submodules": [],
  "provides_permissions": true,
  "provides_drush_commands": false,
  "provides_config_schema": true,
  "provides_plugin_types": ["AiAssistantAction (Plugin/AiAssistantAction)"],
  "provides_config_entities": ["ai_assistant"],
  "consumes_plugin_types": ["AiProvider (from ai)", "AiAgent (from ai_agents, optional)"],
  "routes": {
    "entity.ai_assistant.collection": "/admin/config/ai/ai-assistant",
    "entity.ai_assistant.add_form": "/admin/config/ai/ai-assistant/add",
    "entity.ai_assistant.edit_form": "/admin/config/ai/ai-assistant/{ai_assistant}",
    "entity.ai_assistant.delete_form": "/admin/config/ai/ai-assistant/{ai_assistant}/delete"
  },
  "categories": ["Artificial Intelligence (AI)"],
  "subcategories": ["AI tooling / function calling", "AI agents / taskable AI"],
  "keywords": ["ai", "assistant", "chatbot", "llm", "decoupled", "actions", "function calling", "agent", "thread", "conversation", "system prompt", "ai_assistant"]
}
