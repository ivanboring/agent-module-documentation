{
  "module": "block_visibility_conditions_commerce",
  "version": "2.2.x",
  "part_of": "block_visibility_conditions",
  "cases": [
    {
      "id": "plugin-id",
      "prompt": "What condition plugin does block_visibility_conditions_commerce provide?",
      "expect_contains": ["not_product_type", "Not Product Type"]
    },
    {
      "id": "behavior",
      "prompt": "What does the 'Not Product Type' condition do?",
      "expect_contains": ["hidden", "product", "shown"]
    },
    {
      "id": "deps",
      "prompt": "What does block_visibility_conditions_commerce depend on?",
      "expect_contains": ["block_visibility_conditions", "commerce_product"]
    }
  ]
}
