  "composer_namespace": "drupal/entity_print",
  "composer_requirements": {
    "dompdf/dompdf": ">=2.0.7"
  },
  "dependent_modules": ["drupal:file", "drupal:image"],
  "configure": "entity_print.settings",
  "core_version_requirement": "^9.4 || ^10.0 || ^11",
  "active_installs": 27784,
  "project_url": "https://www.drupal.org/project/entity_print",
  "license": "GPL-2.0-or-later",
  "php_requirement": null,
  "library_dependencies": ["dompdf/dompdf"],
  "suggests": {
    "mikehaertl/phpwkhtmltopdf": "PHP library required to use the Wkhtmltopdf print engine.",
